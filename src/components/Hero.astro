---
// Section 1: Hero / About
---
 
<section id="about" class="hero">
  <div class="hero__inner">
 
    <!-- Logo mark — swap the SVG or img for your real logo -->
    <div class="hero__logo-mark">
      <img src="logos/logo_full.svg" alt="Formify" width="720"/>
    </div>
  
    <h2>
      Helping lifters train safer, and trainers scale smarter
    </h2>
 
    <p class="lead">
      Formify is solving the problem of poor workout form and limited progress
      tracking for everyone from beginners to competitive athletes and trainers.
    </p>
 
    <div class="hero__actions">
      <a href="#waitlist" class="btn btn--primary">Join the waitlist</a>
      <a href="#features" class="btn btn--outline">See how it works</a>
    </div>
 
  </div>
</section>
 
<style>
  .hero__logo-mark {
    margin-bottom: 4rem;
    margin-top: 4rem;
  }

  .hero {
    padding: 8rem 1.5rem 6rem;
    text-align: center;
  }
  
  .hero__inner {
    max-width: var(--container-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  
  .hero__eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-light);
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
  }
  
  .hero h1 {
    max-width: 14ch;
  }
  
  .hero h1 em {
    font-style: italic;
    color: var(--color-accent);
  }
  
  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
</style>
 