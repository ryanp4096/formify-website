---
interface Props {
  videoSrc: string;
  width?: string;
  isVideo?: bool;
  notch?: bool;
  videoStyle?: string;
}

const {
  videoSrc,
  width = "300px",
  isVideo = true,
  notch = false,
  videoStyle = ""
} = Astro.props;
---

<div class="phone-mockup" style={`width: ${width};`}>
  <img class="phone-mockup__top" src={notch ? "/assets/iphone-mockup.png" : "/assets/iphone-mockup-blank.png"} alt="" aria-hidden="true" />
  <div class="phone-mockup__video">
  {
    isVideo
    ?
    <video
        src={videoSrc}
        autoplay
        loop
        muted
        playsinline
        style={videoStyle}
    ></video>
    :
    <img
        src={videoSrc}
        style={videoStyle}
    ></img>
  }
  </div>
  <img class="phone-mockup__shadow" src={notch ? "/assets/iphone-mockup.png" : "/assets/iphone-mockup-blank.png"} alt="" aria-hidden="true" />
</div>

<style>
  .phone-mockup {
    position: relative;
    display: inline-block;
  }

  /* Top frame — sits above the video, no shadow */
  .phone-mockup__top {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
    z-index: 3;
    pointer-events: none;
    user-select: none;
  }

  /* Video — sandwiched between the two frame layers */
  .phone-mockup__video {
    position: absolute;
    z-index: 2;
    object-fit: cover;
    top: 4.3%;
    left: 8.5%;
    width: 83.0%;
    height: 91.4%;
    border-radius: 2.5vmax;
    background-color: #000;
    overflow: hidden;
  }

  .phone-mockup__video img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phone-mockup__video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }


  /* Bottom frame — same image but with drop shadow, renders behind video */
  .phone-mockup__shadow {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    user-select: none;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.35));
  }
</style>