---
const links = [
  { label: "About",    href: "#about"    },
  { label: "Features", href: "#features" },
  { label: "Details",  href: "#details"  },
];
---
 
<header class="navbar">
  <div class="navbar__inner">
    <a href="#" class="navbar__logo"><img src="logos/logo_full.svg" alt="Formify" width="150"/></a>
 
    <nav aria-label="Primary navigation">
      <ul class="navbar__links">
        {links.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
        <li><a href="#waitlist" class="navbar__cta">Join waitlist</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(247, 245, 240, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 0 1.5rem;
  }
  
  .navbar__inner {
    max-width: var(--container-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  
  .navbar__logo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  
  .navbar__links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }
  
  .navbar__links a {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color var(--transition);
  }
  
  .navbar__links a:hover {
    color: var(--color-text);
  }
  
  .navbar__cta {
    background: var(--color-accent);
    color: #fff !important;
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-sm);
    font-weight: 500;
    transition: background var(--transition) !important;
  }
  
  .navbar__cta:hover {
    background: var(--color-accent-hover) !important;
    color: #fff !important;
  }

  @media (max-width: 640px) {
    .navbar__links li:not(:last-child) {
      display: none;
    }
  }
</style>