---
// Section 4: Waitlist signup with embedded form
const tallyLink = "https://tally.so/embed/zxrl9R?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1";
---

<section id="waitlist" class="section waitlist-section">
  <div class="container">

    <div class="waitlist-card">

      <div class="waitlist-card__text">
        <h2>Join the waitlist</h2>
        <p>
          Interested in our product? Join the waitlist to get more details and early access to our app.
        </p>
      </div>

      <div class="form-embed-area">
        <iframe data-tally-src={tallyLink} loading="lazy" width="100%" frameborder="0" marginheight="0" marginwidth="0" title="Formify Waitlist"></iframe>
        <script>var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}</script>
      </div>

    </div>

  </div>
</section>

<style>
  .waitlist-section {
    background: var(--color-bg);
  }

  .waitlist-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: top;
  }

  .waitlist-card__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 20px;
    margin-bottom: 20px;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .waitlist-card__text h2 {
    margin: 0;
  }

  .waitlist-card__text p {
    margin: 0;
  }

  .social-proof {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .social-proof strong {
    color: var(--color-text);
  }

  .form-embed-area {
    display: flex;
    align-items: stretch;
  }

  @media (max-width: 900px) {
    .waitlist-card {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 2.5rem 1.75rem;
    }
  }
</style>